# Cloudflare Pages: enable HTTP Range (206) + edge caching for DuckDB-WASM.
# CF only serves Range from its edge cache; the Pages default
# `cache-control: public, max-age=0, must-revalidate` makes assets uncacheable,
# so partial Parquet reads fall back to full-file downloads. Mark assets cacheable.
# NOTE: Range/206 + edge cache apply on the custom domain (peer.as, full CF CDN);
# *.pages.dev streams from the Pages asset router and may still return 200.

# Vite-hashed JS/CSS — filename carries a content hash → safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static Parquet (large). The frontend appends ?v=<data-version> to every URL,
# so a rebuild changes the URL and busts caches — long caching here is safe and
# also lets CF edge serve Range partial reads.
/data/parquet/*
  Cache-Control: public, max-age=31536000
/data/prefixes/*
  Cache-Control: public, max-age=31536000

# meta.json is the version source — must always be revalidated so a new build is
# seen immediately (304 when unchanged, fresh when the version bumps).
/data/meta.json
  Cache-Control: no-cache
# Other JSON (asnames) is also fetched with ?v= → safe to cache long.
/data/*.json
  Cache-Control: public, max-age=86400
