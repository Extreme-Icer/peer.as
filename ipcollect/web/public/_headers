# Cloudflare Pages: edge + browser caching for DuckDB-WASM data shards.
# The Pages default `cache-control: public, max-age=0, must-revalidate` makes
# assets uncacheable; mark the data dirs cacheable so they persist.
# NOTE: the frontend runs DuckDB in full-GET mode (db.js forceFullHTTPReads) —
# each shard is a single plain GET (200, no Range/HEAD), so it lands 100% in the
# browser HTTP cache (and CF edge) and revisits are zero-network. We no longer
# rely on CF edge Range/206 partial reads (which only worked on the custom domain).

# Vite-hashed JS/CSS — filename carries a content hash → safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static Parquet (large). The frontend appends ?v=<data-version> to every URL,
# so a rebuild changes the URL and busts caches — long caching here is safe and
# also lets CF edge serve Range partial reads.
/data/parquet/*
  Cache-Control: public, max-age=31536000
/data/prefixes/*
  Cache-Control: public, max-age=31536000

# meta.json is the version source — must always be revalidated so a new build is
# seen immediately (304 when unchanged, fresh when the version bumps).
# Keep this an exclusive match: a broader /data/*.json rule would also match
# meta.json and CF concatenates both headers (no-cache + max-age) — ambiguous.
/data/meta.json
  Cache-Control: no-cache
# asnames.json is fetched with ?v= → safe to cache long. (List explicitly, not
# /data/*.json, so it never overlaps the meta.json rule above.)
/data/asnames.json
  Cache-Control: public, max-age=86400

# Service Worker — must revalidate so updates propagate promptly. (Browsers cap
# SW script HTTP caching at 24h regardless, but be explicit.) Long-caching it
# would strand users on a stale SW.
/sw.js
  Cache-Control: no-cache
